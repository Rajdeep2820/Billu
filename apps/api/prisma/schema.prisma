// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  plan      String   @default("starter")
  createdAt DateTime @default(now()) @map("created_at")

  outlets            Outlet[]
  products           Product[]
  transactions       Transaction[]
  users              User[]
  transactionItems   TransactionItem[]
  inventoryMovements InventoryMovement[]
  customers          Customer[]
  acquisitionEvents  AcquisitionEvent[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  outletId  String?  @map("outlet_id")
  name      String
  email     String
  password  String
  role      String   @default("cashier") // cashier | manager | admin
  createdAt DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  outlet       Outlet?      @relation(fields: [outletId], references: [id])
  transactions Transaction[]

  @@unique([tenantId, email])
  @@map("users")
}

model Outlet {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  city      String?
  state     String?
  timezone  String   @default("Asia/Kolkata")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  inventory          Inventory[]
  transactions       Transaction[]
  users              User[]
  transactionItems   TransactionItem[]
  inventoryMovements InventoryMovement[]
  acquisitionEvents  AcquisitionEvent[]

  @@index([tenantId, isActive])
  @@map("outlets")
}

model Product {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  sku        String
  name       String
  category   String   @default("general")
  basePrice  Decimal  @map("base_price") @db.Decimal(12, 2)
  attributes Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  inventory          Inventory[]
  transactionItems   TransactionItem[]
  inventoryMovements InventoryMovement[]

  @@unique([tenantId, sku])
  @@map("products")
}

model Inventory {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  outletId  String   @map("outlet_id")
  productId String   @map("product_id")
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  outlet  Outlet  @relation(fields: [outletId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([outletId, productId])
  @@index([tenantId, outletId])
  @@map("inventory")
}

model Transaction {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  outletId        String   @map("outlet_id")
  cashierId       String?  @map("cashier_id")
  customerId      String?  @map("customer_id")
  customerPhone   String?  @map("customer_phone")
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  paymentMethod   String   @default("cash") @map("payment_method")
  lineItems       Json     @map("line_items")
  receiptPath     String?  @map("receipt_path")
  idempotencyKey  String   @unique @map("idempotency_key")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  outlet           Outlet            @relation(fields: [outletId], references: [id])
  cashier          User?             @relation(fields: [cashierId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])
  transactionItems TransactionItem[]
  inventoryMovements InventoryMovement[]

  @@index([tenantId, createdAt])
  @@index([tenantId, outletId, createdAt])
  @@map("transactions")
}

model TransactionItem {
  id              String   @id @default(uuid())
  transactionId   String   @map("transaction_id")
  tenantId        String   @map("tenant_id")
  outletId        String   @map("outlet_id")
  productId       String?  @map("product_id")
  sku             String
  name            String
  qty             Int
  unitPrice       Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  outlet      Outlet      @relation(fields: [outletId], references: [id])
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, outletId, createdAt])
  @@index([tenantId, productId])
  @@map("transaction_items")
}

model InventoryMovement {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  outletId      String   @map("outlet_id")
  productId     String   @map("product_id")
  transactionId String?  @map("transaction_id")
  type          String   // sale, purchase, adjustment, return, transfer_in, transfer_out
  quantity      Int
  unitCost      Decimal? @map("unit_cost") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  outlet      Outlet       @relation(fields: [outletId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([tenantId, outletId, productId, createdAt])
  @@map("inventory_movements")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  transactions Transaction[]

  @@index([tenantId, phone])
  @@map("customers")
}

model AcquisitionEvent {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  outletId   String?  @map("outlet_id")
  source     String   // walk_in, referral, google, instagram, website, campaign, unknown
  campaign   String?
  customerId String?  @map("customer_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  outlet Outlet? @relation(fields: [outletId], references: [id])

  @@index([tenantId, createdAt])
  @@map("acquisition_events")
}
