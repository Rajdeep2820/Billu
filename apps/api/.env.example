# Copy this file to apps/api/.env and fill in your values

# Database — auto-set by docker-compose (do not change for Docker)
DATABASE_URL="postgresql://postgres@postgres:5432/billu_pos?schema=public"

# Redis — auto-set by docker-compose (do not change for Docker)  
REDIS_URL="redis://:redis_secret@redis:6379"

# JWT
JWT_SECRET="change_this_to_a_long_random_string_in_production"
JWT_EXPIRES_IN="8h"

# Server
PORT=4000
NODE_ENV=production
API_HOST=http://localhost/api

# Cloudflare R2 — Receipt Cloud Storage (S3-compatible)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=billu-pos-receipts

# UPI Payment
MERCHANT_UPI_ID=yourname@upi
MERCHANT_NAME=Your Store Name

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
